# Oracle Fusion Cloud - Basic Auth
ORACLE_HOST=your-fusion-host.oraclecloud.com
ORACLE_USERNAME=your.username@company.com
ORACLE_PASSWORD=your_password

# Redis (ID caching + audit trail)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# PostgreSQL (audit trail)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=p2p_audit
DB_USER=p2p_user
DB_PASSWORD=your_db_password
